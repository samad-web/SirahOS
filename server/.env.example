# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (pooled — used at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@host:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma for migrations only)
DIRECT_URL="postgresql://USER:PASSWORD@host:5432/postgres"

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate-a-random-64-byte-hex-string
JWT_REFRESH_SECRET=generate-a-different-random-64-byte-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend URL (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:8080

# ─── Supabase Leads DB (Ad Leads) ──────────────────────────────────────────────
LEADS_SUPABASE_URL=https://your-leads-project.supabase.co
LEADS_SUPABASE_KEY=your-leads-supabase-service-role-key

# ─── Evolution API (WhatsApp Reminders) ──────────────────────────────────────
EVOLUTION_API_URL=https://your-evolution-api-url/
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name
