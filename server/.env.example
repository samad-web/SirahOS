# ═══════════════════════════════════════════════════════════════════════════════
# Sirahos API — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in the values. Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (pooled — used at runtime via pgBouncer)
# IMPORTANT: set connection_limit=5 (or higher) for production. connection_limit=1
# causes pool exhaustion when the app fires concurrent queries after login.
DATABASE_URL="postgresql://USER:PASSWORD@host:6543/postgres?pgbouncer=true&connection_limit=5"
# Direct connection (used by Prisma for migrations only — bypasses pgBouncer)
DIRECT_URL="postgresql://USER:PASSWORD@host:5432/postgres"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# MUST be "production" in deployed environments (enables HTTPS enforcement,
# Secure cookies, Helmet CSP, reduced rate limits, etc.)
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# These MUST be unique per environment and NEVER shared between dev/staging/prod.
JWT_ACCESS_SECRET=generate-a-random-64-byte-hex-string
JWT_REFRESH_SECRET=generate-a-different-random-64-byte-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Super Admin bootstrap password ──────────────────────────────────────────
# REQUIRED for `prisma db seed`. Must be ≥12 chars. Rotate after first login.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
SUPER_ADMIN_PASSWORD=pick-a-strong-password-at-least-12-chars

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend URL(s). Comma-separated for multiple origins.
# In production: https://your-app.vercel.app (MUST be https for HttpOnly cookies)
CORS_ORIGIN=http://localhost:8080

# ─── Supabase Leads DB (Ad Leads — optional) ────────────────────────────────
LEADS_SUPABASE_URL=https://your-leads-project.supabase.co
LEADS_SUPABASE_KEY=your-leads-supabase-service-role-key

# ─── Evolution API (WhatsApp Reminders — optional) ───────────────────────────
EVOLUTION_API_URL=https://your-evolution-api-url/
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name

# ─── Sentry (Error Tracking — optional, leave blank to disable) ──────────────
# Backend DSN from https://sentry.io/ → project settings → client keys
SENTRY_DSN=
