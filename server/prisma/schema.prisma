// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  LEAD
  DEVELOPER
  TESTER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  REVIEW
  COMPLETED
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

enum TaskType {
  TASK
  FEATURE
  BUG
  IMPROVEMENT
  SUBTASK
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  IN_REVIEW
  VERIFIED
  CLOSED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum PaymentType {
  FULL
  EMI
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum LedgerStatus {
  PAID
  PENDING
}

enum ExpenseCategory {
  OFFICE
  SOFTWARE
  TRAVEL
  SALARY
  MARKETING
  UTILITIES
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALFDAY
  WFH
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
}

enum LeaveStatus {
  REQUESTED
  IN_PROCESS
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  status    CompanyStatus @default(ACTIVE)

  // Feature flags — toggled by Super Admin
  featureBilling    Boolean @default(true)
  featureProjects   Boolean @default(true)
  featureAttendance Boolean @default(true)
  featureLeads      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  projects       Project[]
  tasks          Task[]
  bugReports     BugReport[]
  customers      Customer[]
  invoices       Invoice[]
  ledgerEntries  LedgerEntry[]
  expenses       Expense[]
  attendance     Attendance[]
  leaves         Leave[]
  notes          Note[]
  leadNotes      LeadNote[]
  fines          Fine[]

  @@map("companies")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role
  status       UserStatus @default(ACTIVE)
  initials     String?
  reportsToId  String?
  companyId    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Company assignment (null for SUPER_ADMIN)
  company       Company? @relation(fields: [companyId], references: [id])

  // Manager assignment (self-referential)
  reportsTo     User?   @relation("UserReportsTo", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports User[]  @relation("UserReportsTo")

  // Relations
  managedProjects    Project[]      @relation("ProjectManager")
  leadProjects       Project[]      @relation("ProjectLead")
  projectMemberships ProjectMember[]
  assignedTasks      Task[]         @relation("TaskAssignee")
  createdTasks       Task[]         @relation("TaskCreator")
  reportedBugs       BugReport[]    @relation("BugReporter")
  assignedBugs       BugReport[]    @relation("BugAssignee")
  assignmentsGiven   TaskAssignmentLog[] @relation("AssignmentAssigner")
  assignmentsReceived TaskAssignmentLog[] @relation("AssignmentTarget")
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
  attendance         Attendance[]
  leaves             Leave[]
  reviewedLeaves     LeaveTimeline[]  @relation("LeaveReviewer")
  leaveBalances      LeaveBalance[]
  monthlySummaries   MonthlySummary[]
  leadNotes          LeadNote[]
  fines              Fine[]     @relation("FineUser")
  issuedFines        Fine[]     @relation("FineIssuer")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Project {
  id               String            @id @default(cuid())
  name             String
  client           String
  description      String?
  deadline         DateTime?
  status           ProjectStatus     @default(PLANNING)
  visibility       ProjectVisibility @default(PRIVATE)
  developedBy      String?
  databaseOwnedBy  String?
  databasePassword String?
  githubUrl        String?
  companyId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  company Company? @relation(fields: [companyId], references: [id])
  pmId    String?
  pm      User?   @relation("ProjectManager", fields: [pmId], references: [id], onDelete: SetNull)
  leadId  String?
  lead    User?   @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  members ProjectMember[]
  tasks   Task[]
  bugs    BugReport[]

  @@index([pmId])
  @@index([leadId])
  @@map("projects")
}

model ProjectMember {
  projectId String
  userId    String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        TaskType     @default(TASK)
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  companyId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  company     Company?    @relation(fields: [companyId], references: [id])
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  bugReports  BugReport[]
  assignmentLogs TaskAssignmentLog[]

  @@index([projectId])
  @@index([assigneeId])
  @@map("tasks")
}

model TaskAssignmentLog {
  id         String   @id @default(cuid())
  note       String?
  assignedAt DateTime @default(now())

  taskId       String
  task         Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User   @relation("AssignmentAssigner", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User   @relation("AssignmentTarget", fields: [assignedToId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_assignment_logs")
}

model BugReport {
  id          String      @id @default(cuid())
  title       String
  description String
  severity    BugSeverity @default(MEDIUM)
  status      BugStatus   @default(OPEN)
  resolution  String?
  companyId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  company      Company? @relation(fields: [companyId], references: [id])
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId       String?
  task         Task?   @relation(fields: [taskId], references: [id])
  reportedById String
  reportedBy   User    @relation("BugReporter", fields: [reportedById], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?   @relation("BugAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assignedToId])
  @@map("bug_reports")
}

model Customer {
  id          String         @id @default(cuid())
  name        String
  company     String?
  email       String         @unique
  phone       String?
  gstin       String?
  paymentType PaymentType    @default(FULL)
  totalAmount Float?
  monthlyEmi  Float?
  totalMonths Int?
  notes       String?
  status      CustomerStatus @default(ACTIVE)
  companyId   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant   Company? @relation(fields: [companyId], references: [id])
  invoices Invoice[]

  @@map("customers")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  status        InvoiceStatus @default(PENDING)
  gstRate       Float         @default(18)
  paymentType   PaymentType   @default(FULL)
  emiMonths     Int?
  dueDate       DateTime?
  notes         String?
  companyId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant     Company?      @relation(fields: [companyId], references: [id])
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  items      InvoiceItem[]
  payments   Payment[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  method    String   @default("bank_transfer")
  paidAt    DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model LedgerEntry {
  id          String       @id @default(cuid())
  date        DateTime
  ref         String
  description String
  account     String
  debit       Float        @default(0)
  credit      Float        @default(0)
  category    String?
  status      LedgerStatus @default(PAID)
  companyId   String?
  createdAt   DateTime     @default(now())

  company  Company? @relation(fields: [companyId], references: [id])

  @@index([date])
  @@map("ledger_entries")
}

model POSTransaction {
  id            String   @id @default(cuid())
  clientName    String
  subtotal      Float
  gstRate       Float    @default(18)
  gstAmount     Float
  total         Float
  paymentMethod String   @default("cash")
  createdAt     DateTime @default(now())

  items POSItem[]

  @@map("pos_transactions")
}

model POSItem {
  id       String @id @default(cuid())
  name     String
  quantity Int    @default(1)
  price    Float

  transactionId String
  transaction   POSTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("pos_items")
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  resourceType String
  resourceId   String?
  details      Json?
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ─── Attendance & Leave Models ────────────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  status    AttendanceStatus
  markedAt  DateTime         @default(now())
  note      String?
  companyId String?

  company Company? @relation(fields: [companyId], references: [id])
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("attendance")
}

model Leave {
  id        String      @id @default(cuid())
  leaveType LeaveType
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String
  status    LeaveStatus @default(REQUESTED)
  companyId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company  Company?        @relation(fields: [companyId], references: [id])
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeline LeaveTimeline[]

  @@map("leaves")
}

model LeaveTimeline {
  id        String      @id @default(cuid())
  status    LeaveStatus
  note      String?
  createdAt DateTime    @default(now())

  leaveId    String
  leave      Leave  @relation(fields: [leaveId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User   @relation("LeaveReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@map("leave_timeline")
}

model LeaveBalance {
  id        String    @id @default(cuid())
  leaveType LeaveType
  total     Int       @default(0)
  used      Int       @default(0)
  year      Int

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveType, year])
  @@map("leave_balances")
}

// ─── Monthly Summaries ───────────────────────────────────────────────────────

model MonthlySummary {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  present   Int      @default(0)
  absent    Int      @default(0)
  halfDay   Int      @default(0)
  wfh       Int      @default(0)
  totalDays Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@map("monthly_summaries")
}

// ─── Expenses & Notes ────────────────────────────────────────────────────────

model Expense {
  id            String          @id @default(cuid())
  date          DateTime        @db.Date
  description   String
  amount        Float
  category      ExpenseCategory @default(OTHER)
  paymentMethod String          @default("cash")
  receiptNotes  String?
  companyId     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@map("expenses")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@map("notes")
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  content   String
  authorId  String
  companyId String?
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@map("lead_notes")
}

// ─── Fines ──────────────────────────────────────────────────────────────────

model Fine {
  id        String   @id @default(cuid())
  amount    Float
  reason    String
  paid      Boolean  @default(false)
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company? @relation(fields: [companyId], references: [id])
  userId     String
  user       User     @relation("FineUser", fields: [userId], references: [id], onDelete: Cascade)
  issuedById String
  issuedBy   User     @relation("FineIssuer", fields: [issuedById], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("fines")
}
