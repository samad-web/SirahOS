// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  LEAD
  DEVELOPER
  TESTER
  EDITOR
  DIGITAL_MARKETER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  REVIEW
  COMPLETED
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

enum TaskType {
  TASK
  FEATURE
  BUG
  IMPROVEMENT
  SUBTASK
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  IN_REVIEW
  VERIFIED
  CLOSED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum PaymentType {
  FULL
  EMI
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum LedgerStatus {
  PAID
  PENDING
}

enum ExpenseCategory {
  OFFICE
  SOFTWARE
  TRAVEL
  SALARY
  MARKETING
  UTILITIES
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALFDAY
  WFH
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
}

enum LeaveStatus {
  REQUESTED
  IN_PROCESS
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  status    CompanyStatus @default(ACTIVE)

  // Feature flags — toggled by Super Admin
  featureBilling    Boolean @default(true)
  featureProjects   Boolean @default(true)
  featureAttendance Boolean @default(true)
  featureLeads      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  projects           Project[]
  tasks              Task[]
  bugReports         BugReport[]
  customers          Customer[]
  invoices           Invoice[]
  recurringInvoices  RecurringInvoice[]
  ledgerEntries      LedgerEntry[]
  expenses           Expense[]
  attendance         Attendance[]
  leaves             Leave[]
  notes              Note[]
  todos              Todo[]
  leadNotes          LeadNote[]
  fines              Fine[]
  contentPipeline    Content[]
  notifications      Notification[]

  @@map("companies")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role
  status       UserStatus @default(ACTIVE)
  initials     String?
  avatarUrl    String?    // Base64 data-URL thumbnail (max ~60KB)
  reportsToId  String?
  companyId    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Company assignment (null for SUPER_ADMIN)
  company       Company? @relation(fields: [companyId], references: [id])

  // Manager assignment (self-referential)
  reportsTo     User?   @relation("UserReportsTo", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports User[]  @relation("UserReportsTo")

  // Relations
  managedProjects    Project[]      @relation("ProjectManager")
  leadProjects       Project[]      @relation("ProjectLead")
  projectMemberships ProjectMember[]
  assignedTasks      Task[]         @relation("TaskAssignee")
  createdTasks       Task[]         @relation("TaskCreator")
  reportedBugs       BugReport[]    @relation("BugReporter")
  assignedBugs       BugReport[]    @relation("BugAssignee")
  assignmentsGiven   TaskAssignmentLog[] @relation("AssignmentAssigner")
  assignmentsReceived TaskAssignmentLog[] @relation("AssignmentTarget")
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
  attendance         Attendance[]
  leaves             Leave[]
  reviewedLeaves     LeaveTimeline[]  @relation("LeaveReviewer")
  leaveBalances      LeaveBalance[]
  monthlySummaries   MonthlySummary[]
  leadNotes          LeadNote[]
  fines              Fine[]     @relation("FineUser")
  issuedFines        Fine[]     @relation("FineIssuer")
  notes              Note[]
  todos              Todo[]
  contentAsEditor    Content[]       @relation("ContentEditor")
  contentAsMarketer  Content[]       @relation("ContentMarketer")
  notifications      Notification[]

  @@index([email])
  @@index([companyId])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Project {
  id               String            @id @default(cuid())
  name             String
  client           String
  description      String?
  deadline         DateTime?
  status           ProjectStatus     @default(PLANNING)
  visibility       ProjectVisibility @default(PRIVATE)
  developedBy      String?
  databaseOwnedBy  String?
  databasePassword String?
  githubUrl        String?
  companyId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  company Company? @relation(fields: [companyId], references: [id])
  pmId    String?
  pm      User?   @relation("ProjectManager", fields: [pmId], references: [id], onDelete: SetNull)
  leadId  String?
  lead    User?   @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  members ProjectMember[]
  tasks   Task[]
  bugs    BugReport[]

  @@index([pmId])
  @@index([leadId])
  @@index([companyId])
  @@map("projects")
}

model ProjectMember {
  projectId String
  userId    String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        TaskType     @default(TASK)
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  companyId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  company     Company?    @relation(fields: [companyId], references: [id])
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  bugReports  BugReport[]
  assignmentLogs TaskAssignmentLog[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([companyId])
  @@map("tasks")
}

model TaskAssignmentLog {
  id         String   @id @default(cuid())
  note       String?
  assignedAt DateTime @default(now())

  taskId       String
  task         Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User   @relation("AssignmentAssigner", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User   @relation("AssignmentTarget", fields: [assignedToId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_assignment_logs")
}

model BugReport {
  id          String      @id @default(cuid())
  title       String
  description String
  severity    BugSeverity @default(MEDIUM)
  status      BugStatus   @default(OPEN)
  resolution  String?
  companyId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  company      Company? @relation(fields: [companyId], references: [id])
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId       String?
  task         Task?   @relation(fields: [taskId], references: [id])
  reportedById String
  reportedBy   User    @relation("BugReporter", fields: [reportedById], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?   @relation("BugAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assignedToId])
  @@index([companyId])
  @@map("bug_reports")
}

model Customer {
  id          String         @id @default(cuid())
  name        String
  company     String?
  email       String         @unique
  phone       String?
  gstin       String?
  paymentType PaymentType    @default(FULL)
  totalAmount Float?
  monthlyEmi  Float?
  totalMonths Int?
  notes       String?
  status      CustomerStatus @default(ACTIVE)
  companyId   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant            Company?           @relation(fields: [companyId], references: [id])
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]

  @@index([companyId])
  @@index([status])
  @@map("customers")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  status        InvoiceStatus @default(PENDING)
  gstRate       Float         @default(18)
  paymentType   PaymentType   @default(FULL)
  emiMonths     Int?
  dueDate       DateTime?
  notes         String?
  companyId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant     Company?      @relation(fields: [companyId], references: [id])
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  items      InvoiceItem[]
  payments   Payment[]

  // If this invoice was generated by the recurring scheduler, it points back
  // to its template for traceability.
  recurringInvoiceId String?
  recurringInvoice   RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@index([recurringInvoiceId])
  @@map("invoices")
}

model RecurringInvoice {
  id              String             @id @default(cuid())
  name            String             // e.g. "Acme monthly retainer"
  frequency       RecurringFrequency
  status          RecurringStatus    @default(ACTIVE)
  // First run date (stays fixed — used to compute the cadence anchor).
  startDate       DateTime           @db.Date
  // Optional end date — once reached, status auto-flips to ENDED.
  endDate         DateTime?          @db.Date
  // Next time the scheduler should produce an invoice. Updated after each run.
  nextRunAt       DateTime           @db.Date
  // Last successful run timestamp (null until first execution).
  lastRunAt       DateTime?
  // Template fields — mirror Invoice but without status/items live-state.
  gstRate         Float              @default(18)
  paymentType     PaymentType        @default(FULL)
  emiMonths       Int?
  // How many days after generation the generated invoice is due.
  dueDays         Int                @default(15)
  notes           String?
  // Generated-invoice counter (for display + audit).
  generatedCount  Int                @default(0)
  companyId       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Company?                @relation(fields: [companyId], references: [id])
  customerId      String
  customer        Customer                @relation(fields: [customerId], references: [id])
  items           RecurringInvoiceItem[]
  invoices        Invoice[]

  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([nextRunAt])
  @@map("recurring_invoices")
}

model RecurringInvoiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Float

  recurringInvoiceId String
  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)

  @@map("recurring_invoice_items")
}

model InvoiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  method    String   @default("bank_transfer")
  paidAt    DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model LedgerEntry {
  id          String       @id @default(cuid())
  date        DateTime
  ref         String
  description String
  account     String
  debit       Float        @default(0)
  credit      Float        @default(0)
  category    String?
  status      LedgerStatus @default(PAID)
  companyId   String?
  createdAt   DateTime     @default(now())

  company  Company? @relation(fields: [companyId], references: [id])

  @@index([date])
  @@index([companyId])
  @@map("ledger_entries")
}

model POSTransaction {
  id            String   @id @default(cuid())
  clientName    String
  subtotal      Float
  gstRate       Float    @default(18)
  gstAmount     Float
  total         Float
  paymentMethod String   @default("cash")
  createdAt     DateTime @default(now())

  items POSItem[]

  @@map("pos_transactions")
}

model POSItem {
  id       String @id @default(cuid())
  name     String
  quantity Int    @default(1)
  price    Float

  transactionId String
  transaction   POSTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("pos_items")
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  resourceType String
  resourceId   String?
  details      Json?
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ─── Attendance & Leave Models ────────────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  status    AttendanceStatus
  markedAt  DateTime         @default(now())
  note      String?
  companyId String?

  company Company? @relation(fields: [companyId], references: [id])
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("attendance")
}

model Leave {
  id        String      @id @default(cuid())
  leaveType LeaveType
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String
  status    LeaveStatus @default(REQUESTED)
  companyId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company  Company?        @relation(fields: [companyId], references: [id])
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeline LeaveTimeline[]

  @@map("leaves")
}

model LeaveTimeline {
  id        String      @id @default(cuid())
  status    LeaveStatus
  note      String?
  createdAt DateTime    @default(now())

  leaveId    String
  leave      Leave  @relation(fields: [leaveId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User   @relation("LeaveReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@map("leave_timeline")
}

model LeaveBalance {
  id        String    @id @default(cuid())
  leaveType LeaveType
  total     Int       @default(0)
  used      Int       @default(0)
  year      Int

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveType, year])
  @@map("leave_balances")
}

// ─── Monthly Summaries ───────────────────────────────────────────────────────

model MonthlySummary {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  present   Int      @default(0)
  absent    Int      @default(0)
  halfDay   Int      @default(0)
  wfh       Int      @default(0)
  totalDays Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@map("monthly_summaries")
}

// ─── Expenses & Notes ────────────────────────────────────────────────────────

model Expense {
  id            String          @id @default(cuid())
  date          DateTime        @db.Date
  description   String
  amount        Float
  category      ExpenseCategory @default(OTHER)
  paymentMethod String          @default("cash")
  receiptNotes  String?
  companyId     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([date])
  @@map("expenses")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  userId    String?
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@map("notes")
}

// ─── Todos / Goals ─────────────────────────────────────────────────────────

enum GoalType {
  DAILY
  WEEKLY
  MONTHLY
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  completed   Boolean  @default(false)
  goalType    GoalType @default(DAILY)
  userId      String
  companyId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([goalType])
  @@map("todos")
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  content   String
  authorId  String
  companyId String?
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@map("lead_notes")
}

// ─── Content Pipeline (Editor + Digital Marketer) ───────────────────────────

enum ContentStatus {
  DRAFT
  EDITING
  REVIEW
  COMPLETED
  POSTED
}

enum ContentPlatform {
  YOUTUBE
  INSTAGRAM
  LINKEDIN
}

model Content {
  id            String        @id @default(cuid())
  title         String
  script        String?       @db.Text    // Full script / content copy
  description   String?
  status        ContentStatus @default(DRAFT)

  // Date tracking for the editor pipeline
  assignedDate  DateTime?     // When the video/content was given to the editor
  submittedDate DateTime?     // When the editor marked it complete
  dueDate       DateTime?     // Deadline for the editor

  // Relations
  editorId      String?
  editor        User?         @relation("ContentEditor", fields: [editorId], references: [id], onDelete: SetNull)
  marketerId    String?
  marketer      User?         @relation("ContentMarketer", fields: [marketerId], references: [id], onDelete: SetNull)
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id])

  posts         ContentPost[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([editorId])
  @@index([marketerId])
  @@index([companyId])
  @@index([status])
  @@map("content")
}

model ContentPost {
  id          String          @id @default(cuid())
  platform    ContentPlatform
  postUrl     String?         // URL of the live post (YouTube/IG/LinkedIn link)
  status      String          @default("PENDING") // PENDING | SCHEDULED | POSTED
  scheduledAt DateTime?
  postedAt    DateTime?
  notes       String?

  contentId   String
  content     Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@map("content_posts")
}

// ─── In-app Notifications ───────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String   // e.g. "CONTENT_COMPLETED", "CONTENT_POSTED"
  title     String
  message   String
  read      Boolean  @default(false)
  linkUrl   String?  // Where to navigate on click

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

// ─── Fines ──────────────────────────────────────────────────────────────────

model Fine {
  id        String   @id @default(cuid())
  amount    Float
  reason    String
  paid      Boolean  @default(false)
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company? @relation(fields: [companyId], references: [id])
  userId     String
  user       User     @relation("FineUser", fields: [userId], references: [id], onDelete: Cascade)
  issuedById String
  issuedBy   User     @relation("FineIssuer", fields: [issuedById], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("fines")
}
