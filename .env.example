# ─── Frontend Environment Variables ──────────────────────────────────────────
# These are exposed to the browser (prefixed with VITE_)

# Backend API base URL (no trailing slash)
# Development: leave empty to use Vite proxy (/api)
# Production: set to your Render backend URL
VITE_API_BASE_URL=

# Example for production:
# VITE_API_BASE_URL=https://sirahos-api.onrender.com/api
